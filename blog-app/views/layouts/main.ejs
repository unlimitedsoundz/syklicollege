<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Kestora Blog' %></title>
    <% if (typeof metaDescription !== 'undefined' && metaDescription) { %>
    <meta name="description" content="<%= metaDescription %>">
    <% } %>
    <% if (typeof ogImage !== 'undefined' && ogImage) { %>
    <meta property="og:image" content="<%= ogImage %>">
    <meta property="og:title" content="<%= title %>">
    <meta property="og:description" content="<%= metaDescription || '' %>">
    <meta property="og:type" content="article">
    <% } %>
    <link href="/css/output.css?v=<%= Math.random() %>" rel="stylesheet">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>
<body class="min-h-screen bg-white pt-20">
